{
  "name": "codex-mux",
  "version": "0.1.0",
  "private": false,
  "description": "Terminal multi-agent Codex supervisor powered by Rust",
  "bin": {
    "codex-mux": "bin/codex-mux.js"
  },
  "scripts": {
    "build": "cargo build --release --manifest-path Cargo.toml",
    "release": "node scripts/release.js",
    "test": "cargo test --manifest-path Cargo.toml",
    "postinstall": "node scripts/postinstall.js"
  },
  "files": [
    "bin",
    "scripts",
    "src",
    "Cargo.toml",
    "Cargo.lock"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
